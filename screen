function renderChklist(checks){
  return CL.map(cat=>`
    <div style="font-size:10px;font-weight:600;color:var(--text3);margin:10px 0 5px;text-transform:uppercase;letter-spacing:.07em">${cat.cat}</div>
    ${cat.items.map(it=>{const s=checks[it.id]||'na';const cls=s==='pass'?'cip':s==='fail'?'cif':s==='review'?'cir':'cin';const lbl=s==='pass'?'Pass':s==='fail'?'Fail':s==='review'?'검토':'N·A';
    return`<div class="ci ${cls}" onclick="toggleChk('${it.id}')" id="chk-${it.id}"><div class="ci-txt"><div class="ci-main">${it.main}</div><div class="ci-sub">${it.sub}</div></div><span class="ci-b" id="chkb-${it.id}">${lbl}</span></div>`;
    }).join('')}`).join('');
}

const SC=['na','pass','review','fail'];
function toggleChk(id){
  if(selDeal===null)return;const d=deals[selDeal];
  d.checks[id]=SC[(SC.indexOf(d.checks[id]||'na')+1)%4];
  const s=d.checks[id];const cls=s==='pass'?'cip':s==='fail'?'cif':s==='review'?'cir':'cin';
  document.getElementById('chk-'+id).className='ci '+cls;
  document.getElementById('chkb-'+id).textContent=s==='pass'?'Pass':s==='fail'?'Fail':s==='review'?'검토':'N·A';
  updateScore(selDeal);saveState();
}

function updateScore(i){
  const{p,t}=getScore(deals[i]);const pct=t?Math.round(p/t*100):0;
  const sc=document.getElementById('dd-score');if(!sc)return;
  sc.textContent=p+'/'+t;
  const pf=document.getElementById('dd-pf');pf.style.width=pct+'%';
  pf.style.background=pct>=70?'var(--green)':pct>=40?'var(--amber)':'var(--red)';
  const v=document.getElementById('dd-verdict');
  v.textContent=pct>=70?'✓ 적극 검토':pct>=40?'△ 조건부 검토':'✕ 패스 검토';
  v.style.color=pct>=70?'var(--green)':pct>=40?'var(--amber)':'var(--red)';
}

function calcFi(){
  const v=id=>{const el=document.getElementById('dd-'+id);return el?parseFloat(el.value)||0:0;};
  const rev=v('rev'),ebitda=v('ebitda'),op=v('op'),net=v('net'),asset=v('asset'),debt=v('debt'),revPrev=v('revPrev'),nd=v('nd');
  const set=(id,val,cls)=>{const el=document.getElementById(id);if(el){el.textContent=val;el.className='val '+cls;}};
  const c=(v,g,m)=>v>=g?'cg':v>=m?'ca':'cr';
  const em=rev?(ebitda/rev*100):null;const opm=rev?(op/rev*100):null;const npm=rev?(net/rev*100):null;
  const eq=asset-debt;const dr=eq>0?(debt/eq*100):null;
  const yoy=revPrev?((rev-revPrev)/revPrev*100):null;const nde=ebitda?(nd/ebitda):null;
  set('dc-em',em!=null?em.toFixed(1)+'%':'—',em!=null?c(em,10,5):'cn');
  set('dc-opm',opm!=null?opm.toFixed(1)+'%':'—',opm!=null?c(opm,5,0):'cn');
  set('dc-npm',npm!=null?npm.toFixed(1)+'%':'—',npm!=null?c(npm,5,0):'cn');
  set('dc-dr',dr!=null?dr.toFixed(0)+'%':'—',dr!=null?(dr<=200?'cg':dr<=300?'ca':'cr'):'cn');
  set('dc-yoy',yoy!=null?yoy.toFixed(1)+'%':'—',yoy!=null?c(yoy,10,0):'cn');
  set('dc-nde',nde!=null?nde.toFixed(1)+'x':'—',nde!=null?(nde<=4?'cg':nde<=6?'ca':'cr'):'cn');
}

function addSh(){
  const rows=document.querySelectorAll('.sh-row');
