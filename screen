<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>PE 딜 스크리닝</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+KR:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
:root{--bg:#f8f7f4;--surface:#ffffff;--surface2:#f2f0ec;--border:#e4e0d8;--border2:#d0ccc2;--text:#1a1916;--text2:#6b6760;--text3:#a09c96;--green:#0f6e56;--green-bg:#e1f5ee;--red:#993c1d;--red-bg:#faece7;--amber:#854f0b;--amber-bg:#faeeda;--info:#185fa5;--info-bg:#e6f1fb;--r:8px;--rl:12px}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'IBM Plex Sans KR',sans-serif;background:var(--bg);color:var(--text);font-size:14px;line-height:1.6;min-height:100vh}
.app{display:grid;grid-template-columns:220px 1fr;min-height:100vh}
.sidebar{background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto}
.main{padding:2rem;overflow-x:hidden}
.sidebar-logo{padding:1.5rem 1.25rem 1rem;border-bottom:1px solid var(--border)}
.sidebar-logo h1{font-size:13px;font-weight:600;letter-spacing:.08em;text-transform:uppercase}
.sidebar-logo p{font-size:11px;color:var(--text3);margin-top:2px}
.nav-section{padding:1rem 1.25rem .5rem}
.nav-label{font-size:10px;font-weight:600;color:var(--text3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px}
.nav-item{display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:var(--r);cursor:pointer;font-size:13px;color:var(--text2);transition:all .1s;margin-bottom:1px}
.nav-item:hover{background:var(--surface2);color:var(--text)}
.nav-item.active{background:var(--text);color:#fff}
.nav-icon{font-size:14px;width:18px;text-align:center}
.nav-badge{margin-left:auto;font-size:10px;background:var(--border);color:var(--text2);padding:1px 6px;border-radius:10px;font-family:'IBM Plex Mono',monospace}
.nav-item.active .nav-badge{background:rgba(255,255,255,.2);color:#fff}
.sidebar-footer{margin-top:auto;padding:1rem 1.25rem;border-top:1px solid var(--border);font-size:11px;color:var(--text3)}
.panel{display:none}.panel.active{display:block}
.page-header{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.5rem;gap:1rem;flex-wrap:wrap}
.page-title{font-size:20px;font-weight:600}
.page-sub{font-size:13px;color:var(--text2);margin-top:2px}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--rl);padding:1.25rem;margin-bottom:1rem}
.filter-row{display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap;margin-bottom:1rem}
.fg{display:flex;flex-direction:column;gap:4px}
.fg label{font-size:11px;color:var(--text2);font-weight:500}
input,select,textarea{font-family:'IBM Plex Sans KR',sans-serif;font-size:13px;color:var(--text);background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:6px 10px;outline:none;transition:border-color .15s}
input:focus,select:focus,textarea:focus{border-color:var(--text)}
.btn{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:var(--r);border:none;cursor:pointer;font-size:13px;font-family:'IBM Plex Sans KR',sans-serif;font-weight:500;transition:all .12s;white-space:nowrap}
.btn-primary{background:var(--text);color:#fff}.btn-primary:hover{opacity:.85}
.btn-ghost{background:none;border:1px solid var(--border2);color:var(--text2)}.btn-ghost:hover{background:var(--surface2);color:var(--text)}
.btn-info{background:none;border:1px solid #b5d4f4;color:var(--info)}.btn-info:hover{background:var(--info-bg)}
.btn-sm{padding:4px 10px;font-size:12px}
.chips{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:1rem}
.chip{font-size:12px;padding:3px 10px;border-radius:20px;background:var(--surface2);border:1px solid var(--border);color:var(--text2);font-family:'IBM Plex Mono',monospace}
.chip b{color:var(--text);font-weight:600}
.tbl-wrap{overflow-x:auto;border:1px solid var(--border);border-radius:var(--rl);background:var(--surface);max-height:500px;overflow-y:auto}
table{width:100%;border-collapse:collapse;font-size:12px}
thead{position:sticky;top:0;z-index:2}
th{padding:9px 12px;font-size:11px;font-weight:600;color:var(--text2);text-align:left;background:var(--surface2);border-bottom:1px solid var(--border);white-space:nowrap;cursor:pointer;user-select:none;letter-spacing:.03em}
th:hover{color:var(--text)}
td{padding:8px 12px;border-bottom:1px solid var(--border);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr.pr:hover{background:#fafaf8}
tr.fr{opacity:.4}
.badge{font-size:10px;padding:2px 8px;border-radius:10px;font-weight:600;white-space:nowrap;font-family:'IBM Plex Mono',monospace}
.b-pass{background:var(--green-bg);color:var(--green)}
.b-fail{background:var(--red-bg);color:var(--red)}
.promoted{font-size:11px;color:var(--green);font-weight:600}
.sa{font-size:10px;margin-left:2px}
.cg{color:var(--green);font-weight:500}.cr{color:var(--red)}.ca{color:var(--amber)}.cn{color:var(--text)}
.pagination{display:flex;align-items:center;gap:8px;margin-top:12px;font-size:12px;color:var(--text2)}
.pagination .sp{flex:1}
.deal-panel{display:flex;gap:1.5rem}
.deal-col{width:210px;flex-shrink:0}
.detail-col{flex:1;min-width:0}
.di{padding:10px 12px;border-radius:var(--r);cursor:pointer;border:1px solid transparent;margin-bottom:4px;transition:all .1s}
.di:hover{background:var(--surface2)}
.di.active{border-color:var(--border2);background:var(--surface2)}
.di-name{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.di-sec{font-size:11px;color:var(--text3);margin-top:1px}
.di-score{font-size:11px;margin-top:3px;font-family:'IBM Plex Mono',monospace}
.empty-deal{text-align:center;padding:3rem 1rem;color:var(--text3);font-size:13px}
.sl{font-size:11px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.07em;margin:1.25rem 0 8px}
.sl:first-child{margin-top:0}
.fg4{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:6px}
.fg2{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:10px}
.fg3{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:6px}
.fc{background:var(--surface2);border-radius:var(--r);padding:10px 12px}
.fc label{font-size:11px;color:var(--text2);display:block;margin-bottom:3px}
.fc input{width:100%;border:none;background:transparent;font-size:14px;color:var(--text);font-family:'IBM Plex Mono',monospace;padding:0}
.fc input:focus{outline:none}
.fc.calc{background:var(--surface);border:1px solid var(--border)}
.fc.calc .val{font-size:16px;font-weight:600;font-family:'IBM Plex Mono',monospace}
.sh-row{display:flex;gap:8px;margin-bottom:5px}
.sh-row input{flex:1}
.sh-row input:last-child{max-width:80px}
.add-link{font-size:12px;color:var(--info);background:none;border:none;cursor:pointer;padding:2px 0}
.ci{display:flex;align-items:flex-start;gap:10px;padding:9px 12px;border-radius:var(--r);border:1px solid var(--border);margin-bottom:4px;cursor:pointer;background:var(--surface);transition:all .1s}
.ci.cip{background:var(--green-bg);border-color:#9fe1cb}
.ci.cif{background:var(--red-bg);border-color:#f5c4b3}
.ci.cir{background:var(--amber-bg);border-color:#fac775}
.ci-txt{flex:1}
.ci-main{font-size:12px;font-weight:500}
.ci-sub{font-size:11px;color:var(--text2);margin-top:1px}
.ci-b{font-size:10px;padding:2px 8px;border-radius:10px;flex-shrink:0;font-weight:600;font-family:'IBM Plex Mono',monospace}
.cip .ci-b{background:var(--green-bg);color:var(--green);border:1px solid #9fe1cb}
.cif .ci-b{background:var(--red-bg);color:var(--red);border:1px solid #f5c4b3}
.cir .ci-b{background:var(--amber-bg);color:var(--amber);border:1px solid #fac775}
.cin .ci-b{background:var(--surface2);color:var(--text2);border:1px solid var(--border)}
.score-block{display:flex;align-items:center;gap:14px;padding:14px 16px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--rl);margin:1.25rem 0}
.score-num{font-size:28px;font-weight:700;font-family:'IBM Plex Mono',monospace;min-width:52px}
.pt{flex:1;height:5px;background:var(--border);border-radius:3px;overflow:hidden}
.pf{height:100%;border-radius:3px;transition:width .3s}
.verdict{font-size:13px;font-weight:600}
textarea.memo{width:100%;min-height:100px;resize:vertical;border-radius:var(--r);padding:10px 12px;font-size:13px;line-height:1.6}
.ov-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:1.5rem}
.ov-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--rl);padding:1.25rem}
.ov-label{font-size:11px;color:var(--text2);font-weight:600;text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px}
.ov-val{font-size:32px;font-weight:700;font-family:'IBM Plex Mono',monospace}
.ov-sub{font-size:12px;color:var(--text2);margin-top:3px}
.upload-zone{border:2px dashed var(--border2);border-radius:var(--rl);padding:3rem 2rem;text-align:center;cursor:pointer;transition:all .15s;background:var(--surface)}
.upload-zone:hover{border-color:var(--text2);background:var(--surface2)}
.col-hint{display:inline-block;margin-top:1rem;font-size:12px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--r);padding:8px 14px;color:var(--text2);text-align:left;line-height:2}
.col-hint b{color:var(--text)}
.toast{position:fixed;bottom:1.5rem;right:1.5rem;background:var(--text);color:#fff;padding:10px 18px;border-radius:var(--r);font-size:13px;opacity:0;transition:opacity .2s;pointer-events:none;z-index:999}
.toast.show{opacity:1}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}
</style>
</head>
<body>
<div class="app">
<aside class="sidebar">
  <div class="sidebar-logo">
    <h1>Deal Screener</h1>
    <p>PE 딜 스크리닝 툴</p>
  </div>
  <div class="nav-section">
    <div class="nav-label">스크리닝</div>
    <div class="nav-item active" onclick="showPanel('screen')" id="nav-screen"><span class="nav-icon">⊞</span>매스 스크리닝<span class="nav-badge" id="badge-screen">0</span></div>
    <div class="nav-item" onclick="showPanel('deals')" id="nav-deals"><span class="nav-icon">◎</span>개별 딜 검토<span class="nav-badge" id="badge-deals">0</span></div>
    <div class="nav-item" onclick="showPanel('overview')" id="nav-overview"><span class="nav-icon">▦</span>전체 현황</div>
  </div>
  <div class="nav-section" style="margin-top:.5rem">
    <div class="nav-label">데이터</div>
    <div class="nav-item" onclick="showPanel('upload')" id="nav-upload"><span class="nav-icon">↑</span>파일 업로드</div>
    <div class="nav-item" onclick="exportCSV()"><span class="nav-icon">↓</span>결과 내보내기</div>
  </div>
  <div class="sidebar-footer">데이터는 브라우저에 자동 저장됩니다</div>
</aside>

<main class="main">

<!-- 매스 스크리닝 -->
<div class="panel active" id="panel-screen">
  <div class="page-header">
    <div><div class="page-title">매스 스크리닝</div><div class="page-sub">업종·재무 기준으로 투자 후보군을 필터링합니다</div></div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-ghost btn-sm" onclick="resetFilter()">초기화</button>
      <button class="btn btn-primary btn-sm" onclick="promoteAll()">Pass 전체 → 딜 검토</button>
    </div>
  </div>
  <div class="card">
    <div class="filter-row">
      <div class="fg" style="min-width:140px"><label>업종</label>
        <select id="f-sector" onchange="applyFilter()"><option value="">전체 업종</option><option>반도체</option><option>로봇</option><option>이차전지</option></select>
      </div>
      <div class="fg"><label>매출 최소 (억)</label><input id="f-rev-min" type="number" placeholder="0" style="width:110px" oninput="applyFilter()"/></div>
      <div class="fg"><label>매출 최대 (억)</label><input id="f-rev-max" type="number" placeholder="무제한" style="width:110px" oninput="applyFilter()"/></div>
      <div class="fg"><label>EBITDA 마진 최소 (%)</label><input id="f-em-min" type="number" placeholder="0" style="width:110px" oninput="applyFilter()"/></div>
      <div class="fg"><label>부채비율 최대 (%)</label><input id="f-dr-max" type="number" placeholder="무제한" style="width:110px" oninput="applyFilter()"/></div>
    </div>
    <div class="chips" id="summary-chips"></div>
  </div>
  <div class="tbl-wrap">
    <table>
      <thead><tr>
        <th onclick="sortBy('idx')"># <span class="sa" id="s-idx"></span></th>
        <th onclick="sortBy('name')">회사명 <span class="sa" id="s-name"></span></th>
        <th onclick="sortBy('sector')">업종 <span class="sa" id="s-sector"></span></th>
        <th onclick="sortBy('rev')">매출(억) <span class="sa" id="s-rev">↓</span></th>
        <th onclick="sortBy('ebitda')">EBITDA(억) <span class="sa" id="s-ebitda"></span></th>
        <th onclick="sortBy('em')">EBITDA 마진 <span class="sa" id="s-em"></span></th>
        <th onclick="sortBy('opm')">OPM <span class="sa" id="s-opm"></span></th>
        <th onclick="sortBy('debtRatio')">부채비율 <span class="sa" id="s-debtRatio"></span></th>
        <th onclick="sortBy('yoy')">YoY <span class="sa" id="s-yoy"></span></th>
        <th>스크리닝</th><th>딜 검토</th>
      </tr></thead>
      <tbody id="screen-tbody"></tbody>
    </table>
  </div>
  <div class="pagination">
    <button class="btn btn-ghost btn-sm" id="prev-btn" onclick="changePage(-1)">‹ 이전</button>
    <span id="page-info" style="font-family:'IBM Plex Mono',monospace;font-size:12px"></span>
    <button class="btn btn-ghost btn-sm" id="next-btn" onclick="changePage(1)">다음 ›</button>
    <span class="sp"></span>
    <span id="page-count" style="font-size:12px;color:var(--text3)"></span>
  </div>
</div>

<!-- 개별 딜 검토 -->
<div class="panel" id="panel-deals">
  <div class="page-header">
    <div><div class="page-title">개별 딜 검토</div><div class="page-sub">1단계에서 올라온 기업을 심층 검토합니다</div></div>
  </div>
  <div id="deals-empty" class="empty-deal"><div style="font-size:32px;margin-bottom:12px">◎</div><div>매스 스크리닝에서 기업을 선택해 올려주세요.</div></div>
  <div id="deals-layout" class="deal-panel" style="display:none">
    <div class="deal-col" id="deal-sidebar-list"></div>
    <div class="detail-col" id="deal-detail-area"></div>
  </div>
</div>

<!-- 전체 현황 -->
<div class="panel" id="panel-overview">
  <div class="page-header"><div><div class="page-title">전체 현황</div><div class="page-sub">검토 중인 딜 포트폴리오 요약</div></div></div>
  <div id="overview-content"></div>
</div>

<!-- 파일 업로드 -->
<div class="panel" id="panel-upload">
  <div class="page-header"><div><div class="page-title">파일 업로드</div><div class="page-sub">새 기업 리스트를 추가합니다 (기존 데이터에 병합)</div></div></div>
  <div class="upload-zone" onclick="document.getElementById('file-input').click()">
    <input type="file" id="file-input" accept=".csv,.xlsx,.xls" style="display:none" onchange="handleFile(event)"/>
    <div style="font-size:32px;margin-bottom:10px">⬆</div>
    <h3 style="font-size:15px;font-weight:600;margin-bottom:6px">CSV 또는 Excel 파일 업로드</h3>
    <p style="font-size:13px;color:var(--text2)">클릭하거나 드래그해서 파일을 선택하세요</p>
    <div class="col-hint">필요 컬럼: <b>회사명</b> · <b>업종</b> · <b>매출</b> · <b>EBITDA</b> · <b>영업이익</b> · <b>부채비율</b><br>단위: 억원 / 부채비율: % 숫자만 (예: 145)</div>
  </div>
  <div id="upload-result" style="margin-top:1rem"></div>
</div>

</main>
</div>
<div class="toast" id="toast"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script>
const CL=[
  {cat:"사업 및 시장",items:[
    {id:"c1",main:"핵심 사업 모델 명확성",sub:"주력 제품/서비스·수익 구조·고객군 파악 가능"},
    {id:"c2",main:"시장 지위 및 경쟁 우위",sub:"1~3위권 시장 지위 또는 니치 지배력"},
    {id:"c3",main:"매출 가시성/반복성",sub:"장기계약·구독·정부발주 등 예측 가능 매출 비중"},
  ]},
  {cat:"재무",items:[
    {id:"c4",main:"EBITDA 마진 양호",sub:"10% 이상 또는 개선 트렌드 확인"},
    {id:"c5",main:"OPM 흑자",sub:"영업이익률 흑자 전환 또는 5% 이상"},
    {id:"c6",main:"레버리지 수준 관리 가능",sub:"부채비율 200% 미만 또는 ND/EBITDA 4x 이하"},
    {id:"c7",main:"매출 성장 트렌드",sub:"최근 2~3년 YoY 성장 또는 성장 모멘텀"},
  ]},
  {cat:"지배구조 및 딜 구조",items:[
    {id:"c8",main:"주주 구성 파악 가능",sub:"대주주 지분·우호/비우호 주주 현황"},
    {id:"c9",main:"경영권 확보 가능성",sub:"MBO·구주매출·제3자배정 유상증자 등"},
    {id:"c10",main:"Exit 경로 가시성",sub:"IPO·전략적투자자 매각·세컨더리 등"},
  ]},
  {cat:"리스크",items:[
    {id:"c11",main:"오너 리스크 낮음",sub:"소송·횡령·특수관계자 이슈 없음"},
    {id:"c12",main:"규제/법적 리스크 제한적",sub:"주요 라이선스 보유·인허가 리스크 확인"},
    {id:"c13",main:"회계 투명성",sub:"외부감사 이력·적정의견 여부"},
  ]},
];

