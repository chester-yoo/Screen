// ── FILE UPLOAD ───────────────────────────────────────────────
function handleFile(e){
  const file=e.target.files[0];if(!file)return;
  const ext=file.name.split('.').pop().toLowerCase();
  const reader=new FileReader();
  if(ext==='csv'){
    reader.onload=ev=>{try{const rows=parseCSV(ev.target.result);mergeRows(rows,file.name);}catch(err){alert('파일 오류: '+err.message);}};
    reader.readAsText(file,'UTF-8');
  }else if(ext==='xlsx'||ext==='xls'){
    reader.onload=ev=>{try{const wb=XLSX.read(ev.target.result,{type:'array'});const ws=wb.Sheets[wb.SheetNames[0]];const json=XLSX.utils.sheet_to_json(ws,{defval:''});mergeRows(mapRows(json),file.name);}catch(err){alert('Excel 오류: '+err.message);}};
    reader.readAsArrayBuffer(file);
  }else{alert('CSV 또는 Excel 파일만 지원합니다.');}
  e.target.value='';
}

function parseCSV(text){
  const lines=text.trim().split('\n').map(l=>l.split(',').map(s=>s.trim().replace(/^"|"$/g,'')));
  if(lines.length<2)return[];
  const hdr=lines[0];
  return mapRows(lines.slice(1).filter(r=>r.length>1).map(r=>{const obj={};hdr.forEach((h,i)=>obj[h]=r[i]||'');return obj;}));
}

function mapRows(json){
  if(!json.length)return[];
  const sample=json[0];const keys=Object.keys(sample);
  const fk=(names)=>{for(const n of names){const k=keys.find(k=>k.toLowerCase().includes(n));if(k)return k;}return null;};
  const kN=fk(['회사','company','name','기업']);const kS=fk(['업종','sector','산업']);
  const kR=fk(['매출']);const kE=fk(['ebitda','에비타']);const kO=fk(['영업이익','oper']);
  const kD=fk(['부채비율','부채','debt']);const kRP=fk(['전년']);
  return json.filter(r=>kN&&r[kN]).map(r=>({name:String(r[kN]||'').trim(),sector:String(r[kS]||'기타').trim(),rev:parseFloat(r[kR])||0,ebitda:parseFloat(r[kE])||0,op:parseFloat(r[kO])||0,debtRatio:parseFloat(r[kD])||0,revPrev:parseFloat(r[kRP])||0}));
}

function mergeRows(rows,fname){
  if(!rows.length){document.getElementById('upload-result').innerHTML=`<div style="color:var(--red);padding:1rem">파싱 실패: 컬럼명을 확인해주세요 (회사명, 업종, 매출, EBITDA, 영업이익, 부채비율)</div>`;return;}
  let added=0,updated=0;
  rows.forEach(r=>{
    const existing=allData.find(d=>d.name===r.name);
    if(existing){Object.assign(existing,r,{em:r.rev&&r.ebitda!=null?(r.ebitda/r.rev*100):null,opm:r.rev&&r.op!=null?(r.op/r.rev*100):null,yoy:r.revPrev&&r.rev?((r.rev-r.revPrev)/r.revPrev*100):null});updated++;}
    else{allData.push(cr(r,allData.length));added++;}
  });
  saveState();applyFilter();updateBadges();
  document.getElementById('upload-result').innerHTML=`<div style="background:var(--green-bg);border:1px solid #9fe1cb;border-radius:var(--r);padding:1rem;color:var(--green)"><b>${fname}</b> 업로드 완료 — 신규 ${added}개 추가, ${updated}개 업데이트</div>`;
  toast(added+'개 기업 추가됨');
}

// ── EXPORT ────────────────────────────────────────────────────
function exportCSV(){
  if(!deals.length){toast('내보낼 딜이 없습니다');return;}
  const hdr=['회사명','업종','검토단계','매출(억)','EBITDA(억)','EBITDA마진(%)','OPM(%)','부채비율(%)','Pass율(%)','종합의견'];
  const rows=deals.map(d=>{
    const fi=d.fi||{};const{p,t}=getScore(d);const pct=t?Math.round(p/t*100):0;
    const em=fi.rev&&fi.ebitda?(Number(fi.ebitda)/Number(fi.rev)*100).toFixed(1):'';
    const opm=fi.rev&&fi.op?(Number(fi.op)/Number(fi.rev)*100).toFixed(1):'';
    return[d.name,d.sector,d.stage||'',fi.rev||'',fi.ebitda||'',em,opm,fi.debtRatio||'',pct,d.memo||''].map(v=>`"${String(v).replace(/"/g,'""')}"`).join(',');
  });
  const csv='\uFEFF'+hdr.join(',')+'\n'+rows.join('\n');
  const a=document.createElement('a');a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download='PE_딜_스크리닝_'+new Date().toISOString().slice(0,10)+'.csv';a.click();
  toast('CSV 내보내기 완료');
}

// ── TOAST ─────────────────────────────────────────────────────
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2200);}

// ── DRAG DROP ─────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded',()=>{
  init();
  const uz=document.querySelector('.upload-zone');
  uz.addEventListener('dragover',e=>{e.preventDefault();uz.style.borderColor='var(--text)';});
  uz.addEventListener('dragleave',()=>uz.style.borderColor='');
  uz.addEventListener('drop',e=>{e.preventDefault();uz.style.borderColor='';const f=e.dataTransfer.files[0];if(f){const dt=new DataTransfer();dt.items.add(f);document.getElementById('file-input').files=dt.files;handleFile({target:{files:dt.files,value:''}});}});
});
</script>
</body>
</html>
