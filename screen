let allData=[],filtered=[],deals=[],selDeal=null,sortKey='rev',sortDir=-1,page=0;
const PS=50;

function saveState(){try{localStorage.setItem('pe_d',JSON.stringify(allData));localStorage.setItem('pe_deals',JSON.stringify(deals));}catch(e){}}
function loadState(){try{const d=localStorage.getItem('pe_d');const dl=localStorage.getItem('pe_deals');if(d)allData=JSON.parse(d);if(dl)deals=JSON.parse(dl);}catch(e){}}
function cr(r,i){const em=r.rev&&r.ebitda!=null?(r.ebitda/r.rev*100):null;const opm=r.rev&&r.op!=null?(r.op/r.rev*100):null;const yoy=r.revPrev&&r.rev?((r.rev-r.revPrev)/r.revPrev*100):null;return{...r,em,opm,yoy,idx:i+1};}

function init(){
  loadState();
  if(!allData.length)allData=SEED.filter(r=>r.name&&r.rev!=null).map(cr);
  applyFilter();updateBadges();
}

function showPanel(name){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('panel-'+name).classList.add('active');
  const ni=document.getElementById('nav-'+name);if(ni)ni.classList.add('active');
  if(name==='overview')renderOverview();
  if(name==='deals')renderDealSidebar();
}

function updateBadges(){
  document.getElementById('badge-screen').textContent=allData.length;
  document.getElementById('badge-deals').textContent=deals.length;
}

function applyFilter(){
  const sec=document.getElementById('f-sector').value;
  const rmin=parseFloat(document.getElementById('f-rev-min').value)||0;
  const rmax=parseFloat(document.getElementById('f-rev-max').value)||Infinity;
  const emMin=parseFloat(document.getElementById('f-em-min').value);
  const drMax=parseFloat(document.getElementById('f-dr-max').value)||Infinity;
  const hasEm=!isNaN(emMin);
  filtered=allData.map(r=>{
    const secOk=!sec||r.sector===sec;
    const revOk=r.rev>=rmin&&r.rev<=rmax;
    const emOk=!hasEm||(r.em!=null&&r.em>=emMin);
    const drOk=r.debtRatio==null||r.debtRatio<=drMax;
    return{...r,pass:secOk&&revOk&&emOk&&drOk};
  });
  doSort();page=0;renderTable();
}

function resetFilter(){
  ['f-sector','f-rev-min','f-rev-max','f-em-min','f-dr-max'].forEach(id=>{const el=document.getElementById(id);if(el.tagName==='SELECT')el.value='';else el.value='';});
  applyFilter();
}

function sortBy(k){if(sortKey===k)sortDir*=-1;else{sortKey=k;sortDir=-1;}doSort();page=0;renderTable();}
function doSort(){
  filtered.sort((a,b)=>{let av=a[sortKey],bv=b[sortKey];if(av==null&&bv==null)return 0;if(av==null)return 1;if(bv==null)return -1;if(typeof av==='string')return av.localeCompare(bv)*sortDir;return(av-bv)*sortDir;});
  ['idx','name','sector','rev','ebitda','em','opm','debtRatio','yoy'].forEach(k=>{const el=document.getElementById('s-'+k);if(el)el.textContent=k===sortKey?(sortDir>0?'↑':'↓'):'';});
}

function renderTable(){
  const pass=filtered.filter(r=>r.pass);
  document.getElementById('summary-chips').innerHTML=
    `<div class="chip">전체 <b>${filtered.length}</b></div><div class="chip">Pass <b style="color:var(--green)">${pass.length}</b></div><div class="chip">Fail <b style="color:var(--red)">${filtered.length-pass.length}</b></div>`;
  const start=page*PS,end=start+PS,pg=filtered.slice(start,end);
  const f=(n,d=1)=>n!=null?n.toFixed(d):'—';
  const cc=(v,g,m)=>v!=null?(v>=g?'cg':v>=m?'ca':'cr'):'cn';
  document.getElementById('screen-tbody').innerHTML=pg.map((r,i)=>{
    const prom=deals.find(d=>d.name===r.name);
    return`<tr class="${r.pass?'pr':'fr'}">
      <td style="color:var(--text3);font-family:'IBM Plex Mono',monospace">${start+i+1}</td>
      <td style="font-weight:600;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${r.name}</td>
      <td><span style="font-size:11px;padding:1px 7px;border-radius:8px;background:var(--surface2);border:1px solid var(--border)">${r.sector}</span></td>
      <td style="font-family:'IBM Plex Mono',monospace">${r.rev!=null?r.rev.toLocaleString():'—'}</td>
      <td style="font-family:'IBM Plex Mono',monospace">${r.ebitda!=null?r.ebitda.toLocaleString():'—'}</td>
      <td class="${cc(r.em,10,5)}" style="font-family:'IBM Plex Mono',monospace">${r.em!=null?f(r.em)+'%':'—'}</td>
      <td class="${cc(r.opm,5,0)}" style="font-family:'IBM Plex Mono',monospace">${r.opm!=null?f(r.opm)+'%':'—'}</td>
      <td class="${r.debtRatio!=null?(r.debtRatio<=200?'cg':r.debtRatio<=300?'ca':'cr'):'cn'}" style="font-family:'IBM Plex Mono',monospace">${r.debtRatio!=null?r.debtRatio+'%':'—'}</td>
      <td class="${cc(r.yoy,10,0)}" style="font-family:'IBM Plex Mono',monospace">${r.yoy!=null?f(r.yoy)+'%':'—'}</td>
      <td><span class="badge ${r.pass?'b-pass':'b-fail'}">${r.pass?'Pass':'Fail'}</span></td>
      <td>${prom?`<span class="promoted">✓ 추가됨</span>`:(r.pass?`<button class="btn btn-info btn-sm" onclick="promoteDeal('${r.name.replace(/'/g,"\\'")}')">→ 딜 검토</button>`:'—')}</td>
    </tr>`;
  }).join('');
  const total=Math.ceil(filtered.length/PS);
  document.getElementById('page-info').textContent=`${page+1} / ${total}`;
  document.getElementById('page-count').textContent=`총 ${filtered.length}개`;
